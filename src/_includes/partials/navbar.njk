<nav class="topnav" aria-label="{% if lang == 'es' %}Navegación principal{% elif lang == 'it' %}Navigazione principale{% elif lang == 'fr' %}Navigation principale{% else %}Main navigation{% endif %}">
  <a href="/{{ lang }}/" class="topnav__brand">{{ site.name }}</a>

  <button class="topnav__toggle" id="menu-toggle" aria-label="{{ ui[lang].toggle_menu }}" aria-expanded="false" aria-controls="topnav-menu">&#9776;</button>

  <div class="topnav__menu" id="topnav-menu">
    <ul class="topnav__links">
      {% set homeUrl = '/' + lang + '/' %}
      <li><a href="/{{ lang }}/"{% if page.url == homeUrl %} aria-current="page"{% endif %}>{{ ui[lang].nav_home }}</a></li>
      {% for item in navigation.main %}
      {% set itemUrl = '/' + lang + '/' + item.slug + '/' %}
      <li><a href="/{{ lang }}/{{ item.slug }}/"{% if page.url == itemUrl %} aria-current="page"{% endif %}>{{ item[lang] }}</a></li>
      {% endfor %}
    </ul>

    <div class="topnav__actions">
      <button type="button" class="theme-toggle" id="theme-toggle" aria-label="{{ ui[lang].toggle_dark_mode }}">
        <span class="theme-toggle__icon" aria-hidden="true"></span>
      </button>
      <div class="topnav__lang-dropdown">
        <button type="button" class="topnav__lang-btn" aria-expanded="false" aria-label="{{ ui[lang].change_language | default('Change language') }}">
          <span aria-hidden="true">🌐</span> {{ lang | upper }}
        </button>
        <ul class="topnav__lang-menu">
          {% for l in site.languages %}
          {% if l.code != lang %}
          <li><a href="{{ page.url | toLang(lang, l.code) }}">{{ l.name }}</a></li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</nav>
