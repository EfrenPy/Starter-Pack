# Custom 404 page
ErrorDocument 404 /404.html

# Temporary redirect from root to /en/ (302 so browser doesn't cache it permanently;
# index.html JS detects preferred language from localStorage/navigator.language)
RewriteEngine On
RewriteRule ^/?$ /en/ [R=302,L]

# 301 redirects for old URL structures
# Flattened: /xx/technical/kerberos-ssh/vscode-remote/ → /xx/technical/vscode-remote/
RewriteRule ^(en|es|it|fr)/technical/kerberos-ssh/vscode-remote/?$ /$1/technical/vscode-remote/ [R=301,L]

# Flattened: /xx/cern-taxation/modelo-720/ → /xx/modelo-720/
RewriteRule ^(en|es|it|fr)/cern-taxation/modelo-720/?$ /$1/modelo-720/ [R=301,L]

# Flattened: /xx/faq/housing-guide/ → /xx/housing-guide/
RewriteRule ^(en|es|it|fr)/faq/housing-guide/?$ /$1/housing-guide/ [R=301,L]

# Flattened: /xx/faq/health-insurance/ → /xx/health-insurance/
RewriteRule ^(en|es|it|fr)/faq/health-insurance/?$ /$1/health-insurance/ [R=301,L]

# Renamed: /xx/taxes/ → /xx/cern-taxation/
RewriteRule ^(en|es|it|fr)/taxes/?$ /$1/cern-taxation/ [R=301,L]

# Renamed: /xx/residence-permit/ → /xx/permits-registration/
RewriteRule ^(en|es|it|fr)/residence-permit/?$ /$1/permits-registration/ [R=301,L]

# Renamed: /xx/cross-border-commute/ → /xx/cross-border-shopping/
RewriteRule ^(en|es|it|fr)/cross-border-commute/?$ /$1/cross-border-shopping/ [R=301,L]

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Cache control
<IfModule mod_expires.c>
  ExpiresActive On

  # Static assets — 1 year
  <FilesMatch "\.(js|css|woff2?|png|jpg|svg|ico|webmanifest)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML pages — 1 hour
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 1 hour"
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
